# 环境
VITE_NODE_ENV=development

# 接口前缀
# 本地开发：留空，走 vite 代理
# 测试环境：改成 http://服务器IP（nginx 监听 80 端口），如 http://8.130.xxx.xxx
VITE_API_BASE_PATH=

# 打包路径
VITE_BASE_PATH=/

# 标题
VITE_APP_TITLE=ElementAdmin

# 是否全量引入element-plus样式
VITE_USE_ALL_ELEMENT_PLUS_STYLE=true

# 关闭mock，使用真实接口
VITE_USE_MOCK=false

# 是否使用在线图标
VITE_USE_ONLINE_ICON=true

# 是否隐藏全局设置按钮
VITE_HIDE_GLOBAL_SETTING=false
